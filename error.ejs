<%- include('partials/header') %>

<section class="error-page" aria-labelledby="error-page-title">
  <div class="tool-detail-panel error-page__panel">
    <p class="section-heading__eyebrow">页面提示</p>
    <h2 id="error-page-title" class="section-heading__title">
      <%= typeof errorTitle !== 'undefined' ? errorTitle : '页面暂时无法访问' %>
    </h2>
    <p class="error-page__message">
      <%= typeof errorMessage !== 'undefined' ? errorMessage : '请稍后重试，或返回上一级页面继续浏览。' %>
    </p>
    <p class="error-page__action">
      <a class="button button--ghost" href="<%= typeof backLink !== 'undefined' ? backLink : '/' %>">
        <%= typeof backText !== 'undefined' ? backText : '返回首页' %>
      </a>
    </p>
  </div>
</section>

<%- include('partials/footer') %>
