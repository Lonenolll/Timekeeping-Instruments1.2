<%- include('../partials/header') %>

<section class="media-page" aria-labelledby="admin-video-form-title">
  <header class="media-page__hero">
    <p class="media-page__eyebrow">后台管理</p>
    <h2 id="admin-video-form-title" class="media-page__title">新增视频资源</h2>
    <p class="media-page__subtitle">
      通过这个基础表单录入与计时工具相关的视频内容，适合课程项目阶段的轻量后台维护。
    </p>
  </header>

  <% if (successMessage) { %>
    <div class="notice-panel">
      <%= successMessage %>
    </div>
  <% } %>

  <% if (errorMessage) { %>
    <div class="tool-detail-panel">
      <p><%= errorMessage %></p>
    </div>
  <% } %>

  <section class="media-filter" aria-labelledby="admin-video-form-section-title">
    <div class="section-heading">
      <p class="section-heading__eyebrow">视频录入</p>
      <h3 id="admin-video-form-section-title" class="section-heading__title">填写视频基础信息</h3>
    </div>

    <% if (tools.length) { %>
      <form class="filter-form" action="/admin/videos/new" method="post">
        <div class="filter-form__group">
          <label for="timing_tool_id">计时工具</label>
          <select id="timing_tool_id" name="timing_tool_id" required>
            <option value="">请选择所属计时工具</option>
            <% tools.forEach((tool) => { %>
              <option
                value="<%= tool.id %>"
                <%= String(formData.timing_tool_id) === String(tool.id) ? 'selected' : '' %>
              >
                <%= tool.name_zh %> / <%= tool.name_en %>
              </option>
            <% }) %>
          </select>
        </div>

        <div class="filter-form__group">
          <label for="title_zh">中文标题</label>
          <input id="title_zh" name="title_zh" type="text" value="<%= formData.title_zh %>" required>
        </div>

        <div class="filter-form__group">
          <label for="title_en">英文标题</label>
          <input id="title_en" name="title_en" type="text" value="<%= formData.title_en %>" required>
        </div>

        <div class="filter-form__group">
          <label for="language">语言</label>
          <input id="language" name="language" type="text" value="<%= formData.language %>" placeholder="如：中文 / 英文 / 中英双语">
        </div>

        <div class="filter-form__group">
          <label for="video_url">视频地址</label>
          <input id="video_url" name="video_url" type="text" value="<%= formData.video_url %>" required placeholder="如：https://example.com/video.mp4">
        </div>

        <div class="filter-form__group">
          <label for="duration">时长</label>
          <input id="duration" name="duration" type="text" value="<%= formData.duration %>" placeholder="如：05:32">
        </div>

        <div class="filter-form__group">
          <label for="thumbnail">缩略图</label>
          <input id="thumbnail" name="thumbnail" type="text" value="<%= formData.thumbnail %>" placeholder="如：/images/thumbnails/video-demo.jpg">
        </div>

        <div class="filter-form__group" style="flex-basis: 100%;">
          <label for="description">简介</label>
          <textarea
            id="description"
            name="description"
            rows="5"
            style="width: 100%; border: 1px solid rgba(92, 132, 201, 0.24); border-radius: 18px; padding: 12px 16px; color: var(--ink-primary); background: rgba(255, 255, 255, 0.05);"
          ><%= formData.description %></textarea>
        </div>

        <button class="button button--primary" type="submit">提交视频数据</button>
      </form>
    <% } else { %>
      <div class="tool-detail-panel">
        <p>当前还没有可选的计时工具。请先录入计时工具，再新增视频资源。</p>
      </div>
    <% } %>
  </section>
</section>

<%- include('../partials/footer') %>
